# Optional. The app works fine anonymously (TfL allows ~50 requests/min without
# a key, and this server caches aggressively), but if you hit rate limits you
# can register a free account at https://api-portal.tfl.gov.uk and paste your
# key here to raise the limit to 500 requests/min.
TFL_APP_KEY=

# Port the Express server listens on.
PORT=3001
